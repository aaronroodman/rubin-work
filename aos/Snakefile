# ----------------------------------------------------------------------
# AOS FAM pipeline (Snakemake).  Phase 1: mktable + fit per chunk ->
# combine -> plots, organised under output/<param_set>/.
#
# Config: snake_config.yaml (param_sets -> date chunks); Butler/collection
# definitions in param_sets.yaml (referenced by name).
#
#   snakemake -n                 # dry-run: show the plan
#   snakemake -j4                # build (4 parallel; add --resources mem_mb=... on RSP)
#   snakemake --dag | dot -Tpng > dag.png
#
# Layout:
#   output/<ps>/chunks/<dmin>_<dmax>/{donuts,fits,visits}.parquet   (per chunk)
#   output/<ps>/{donuts,fits,visits}.parquet                        (combined)
#   output/<ps>/plots/                                              (on combined)
# ----------------------------------------------------------------------
import os
import yaml

# Deterministic threading regardless of how the launching terminal set these.
# A NUMEXPR_MAX_THREADS pinned to 1 (some JupyterHub sessions) crashes mktable;
# force a safe cap.  One thread per job — parallelism comes from `snakemake -j`
# (the RSP terminal gets ~4 usable cores via the cgroup cpu quota), so this
# fills the cores without N_jobs x N_threads oversubscription.  Set in the
# Snakefile process env, which the rule shell subprocesses inherit.
os.environ['NUMEXPR_MAX_THREADS'] = '8'
os.environ['NUMEXPR_NUM_THREADS'] = '1'
os.environ['OMP_NUM_THREADS'] = '1'
os.environ['OPENBLAS_NUM_THREADS'] = '1'
os.environ['MKL_NUM_THREADS'] = '1'

PARAM_SETS = yaml.safe_load(open("param_sets.yaml"))
CFG        = yaml.safe_load(open("snake_config.yaml"))["param_sets"]
PSETS      = list(CFG)

# Phase 2: measured-intrinsic configs (optional file), via code/mi_config.py.
import sys as _sys
_sys.path.insert(0, "code")
import mi_config as _mc
MI_DOC = _mc.load_doc("mi_config.yaml") if os.path.exists("mi_config.yaml") else {}
MI_PSETS = list((MI_DOC or {}).get("measured_intrinsics", {}))

def phrase(ps):                                   # matches run_pipeline / intrinsics_lib
    r = PARAM_SETS.get(ps, {})
    if r.get("collection_phrase"):
        return r["collection_phrase"]
    parts = r["fam_collections"][0].split("/")
    return parts[2] if (parts[0] == "u" and len(parts) > 2) else r["fam_collections"][0]

def chunks(ps):  return [(int(a), int(b)) for a, b in CFG[ps]["chunks"]]
def coord(ps):   return CFG[ps].get("coord_sys", "OCS")
def chunk_files(ps, name):
    return [f"output/{ps}/chunks/{a}_{b}/{name}" for a, b in chunks(ps)]

# ---- Phase 2 (measured intrinsic) helpers, driven by mi_config.yaml ----
def mi_names(ps):   return _mc.mi_names(ps, doc=MI_DOC)
def mi_rotbins(ps, mi): return _mc.rotator_bins(_mc.load_mi_config(ps, mi, doc=MI_DOC))
def mi_bin_grids(ps, mi):
    return [f"output/{ps}/{mi}/build/rot_{lo:g}_{hi:g}/intrinsic_grid.parquet"
            for lo, hi in mi_rotbins(ps, mi)]
MI_PAIRS = [(ps, mi) for ps in MI_PSETS for mi in mi_names(ps)]

# param_set names have no slash; keeps output/<ps>/X.parquet (combined)
# distinct from output/<ps>/chunks/<d>_<d>/X.parquet (per chunk).
wildcard_constraints:
    ps   = r"[A-Za-z0-9_.+-]+",
    dmin = r"\d{8}",
    dmax = r"\d{8}",
    mi   = r"[A-Za-z0-9_.+-]+",
    lo   = r"-?\d+(\.\d+)?",
    hi   = r"-?\d+(\.\d+)?",

rule all:
    input:
        expand("output/{ps}/donuts.parquet",              ps=PSETS),
        expand("output/{ps}/fits.parquet",                ps=PSETS),
        expand("output/{ps}/visits.parquet",              ps=PSETS),
        expand("output/{ps}/plots/trio_comparison_all.pdf", ps=PSETS),
        # per-donut aberration-pair (primary->secondary) analysis
        expand("output/{ps}/plots/aberration_pairs.pdf", ps=PSETS),
        # Phase 2: measured-intrinsic refit per (param_set, mi_name)
        [f"output/{ps}/{mi}/fits.parquet" for ps, mi in MI_PAIRS],
        # averaged-DOF LUT per (param_set, mi_name)
        [f"output/{ps}/{mi}/lut/lut.parquet" for ps, mi in MI_PAIRS],

# ---- per chunk: mktable (Butler) -> donuts + visits ----
rule mktable:
    output:
        donuts = "output/{ps}/chunks/{dmin}_{dmax}/donuts.parquet",
        visits = "output/{ps}/chunks/{dmin}_{dmax}/visits.parquet",
    params:
        cdir = lambda w: f"output/{w.ps}/chunks/{w.dmin}_{w.dmax}",
        ph   = lambda w: phrase(w.ps),
    resources: mem_mb=4000
    log: "logs/{ps}.{dmin}_{dmax}.mktable.log"
    shell:
        r"""
        python code/run_mktable.py --param-set {wildcards.ps} \
            --day-obs-min {wildcards.dmin} --day-obs-max {wildcards.dmax} \
            --output-dir {params.cdir} > {log} 2>&1
        mv {params.cdir}/{params.ph}_{wildcards.dmin}_{wildcards.dmax}.parquet {output.donuts}
        mv {params.cdir}/{params.ph}_{wildcards.dmin}_{wildcards.dmax}_visits.parquet {output.visits}
        """

# ---- per chunk: Double-Zernike fit ----
rule fit:
    input:
        donuts = "output/{ps}/chunks/{dmin}_{dmax}/donuts.parquet",
        visits = "output/{ps}/chunks/{dmin}_{dmax}/visits.parquet",
    output: "output/{ps}/chunks/{dmin}_{dmax}/fits.parquet"
    params: coord = lambda w: coord(w.ps)
    resources: mem_mb=4000
    log: "logs/{ps}.{dmin}_{dmax}.fit.log"
    shell:
        "python code/run_dz_fit.py {input.donuts} --coord-sys {params.coord} "
        "--visits {input.visits} --output {output} > {log} 2>&1"

# ---- combine chunks -> one param_set-level table each ----
# The called script is declared as an input so editing it triggers a re-run
# (Snakemake's code-change trigger only watches a rule's shell command, not the
# external scripts it calls).  mktable deliberately does NOT track its script —
# it would force expensive Butler re-queries on any intrinsics_lib edit.
rule combine_donuts:
    input:
        chunks = lambda w: chunk_files(w.ps, "donuts.parquet"),
        script = "code/combine_parquets.py",
    output: "output/{ps}/donuts.parquet"
    resources: mem_mb=3000
    log:    "logs/{ps}.combine_donuts.log"
    shell:  "python code/combine_parquets.py {input.chunks} --output {output} > {log} 2>&1"

rule combine_fits:
    input:
        chunks = lambda w: chunk_files(w.ps, "fits.parquet"),
        script = "code/combine_parquets.py",
    output: "output/{ps}/fits.parquet"
    resources: mem_mb=2000
    log:    "logs/{ps}.combine_fits.log"
    shell:  "python code/combine_parquets.py {input.chunks} --output {output} > {log} 2>&1"

rule combine_visits:
    input:
        chunks = lambda w: chunk_files(w.ps, "visits.parquet"),
        script = "code/combine_parquets.py",
    output: "output/{ps}/visits.parquet"
    resources: mem_mb=2000
    log:    "logs/{ps}.combine_visits.log"
    shell:  "python code/combine_parquets.py {input.chunks} --output {output} > {log} 2>&1"

# ---- validation plots on the combined tables ----
rule plots:
    input:
        donuts = "output/{ps}/donuts.parquet",
        fits   = "output/{ps}/fits.parquet",
        script = "code/run_dz_plots.py",
    output: "output/{ps}/plots/trio_comparison_all.pdf"
    params: coord = lambda w: coord(w.ps)
    # run_dz_plots loads the full combined donut table; astropy materializes the
    # zk_* list columns as Python objects, so a single job can use ~10 GiB for a
    # multi-million-row set.  Declare it large so the scheduler runs plots one at
    # a time (two concurrent jobs OOM the 16 GiB allocation).
    resources: mem_mb=12000
    log: "logs/{ps}.plots.log"
    shell:
        "python code/run_dz_plots.py {input.donuts} {input.fits} "
        "--coord-sys {params.coord} --output-dir output/{wildcards.ps}/plots "
        "--no-single-image > {log} 2>&1"

# ---- per-donut primary->secondary aberration-pair analysis ----
rule aberration_pairs:
    input:
        donuts = "output/{ps}/donuts.parquet",
        visits = "output/{ps}/visits.parquet",
        fits   = "output/{ps}/fits.parquet",
        config = "analysis_config.yaml",
        script = "code/run_aberration_pairs.py",
    output: "output/{ps}/plots/aberration_pairs.pdf"
    params: coord = lambda w: coord(w.ps)
    # streams the donut zk_<coord> column by row group; lighter than run_dz_plots.
    resources: mem_mb=8000
    log: "logs/{ps}.aberration_pairs.log"
    shell:
        "python code/run_aberration_pairs.py {input.donuts} "
        "--visits {input.visits} --fits {input.fits} --coord-sys {params.coord} "
        "--param-set {wildcards.ps} --label {wildcards.ps} "
        "--output-dir output/{wildcards.ps}/plots > {log} 2>&1"

# ======================================================================
# Phase 2 — measured intrinsic, per (param_set, mi_name) from mi_config.yaml
#   build_intrinsic (per rotator bin) -> intrinsic_split -> intrinsic_sidecar
#   -> refit_mi (DZ fits using the measured intrinsic).
# RSP-only (needs lsst.ts.ofc/wep + TS_CONFIG_MTTCS_DIR + batoid height maps).
# ======================================================================

# ---- per rotator bin: build the Path-A measured-intrinsic grid ----
rule build_intrinsic:
    input:
        donuts = "output/{ps}/donuts.parquet",
        visits = "output/{ps}/visits.parquet",
        fits   = "output/{ps}/fits.parquet",
        config = "mi_config.yaml",
        script = "code/run_build_intrinsic.py",
        lib    = "code/measured_intrinsic.py",
        plots  = "code/intrinsic_build_plots.py",
    output: "output/{ps}/{mi}/build/rot_{lo}_{hi}/intrinsic_grid.parquet"
    resources: mem_mb=8000
    log: "logs/{ps}.{mi}.build_rot_{lo}_{hi}.log"
    shell:
        "python code/run_build_intrinsic.py --param-set {wildcards.ps} "
        "--mi-name {wildcards.mi} --rot-min {wildcards.lo} --rot-max {wildcards.hi} "
        "> {log} 2>&1"

# ---- decompose the per-bin grids into OCS + CCS ----
rule intrinsic_split:
    input:
        grids  = lambda w: mi_bin_grids(w.ps, w.mi),
        config = "mi_config.yaml",
        script = "code/run_intrinsic_split.py",
        lib    = "code/intrinsic_split.py",
    output:
        parquet = "output/{ps}/{mi}/intrinsic_split.parquet",
        decomp  = "output/{ps}/{mi}/intrinsic_split_decomp.npz",
        plots   = "output/{ps}/{mi}/intrinsic_split.pdf",
    resources: mem_mb=4000
    log: "logs/{ps}.{mi}.intrinsic_split.log"
    shell:
        "python code/run_intrinsic_split.py --param-set {wildcards.ps} "
        "--mi-name {wildcards.mi} > {log} 2>&1"

# ---- per-donut measured-intrinsic sidecar (row-aligned to donuts.parquet) ----
rule intrinsic_sidecar:
    input:
        decomp = "output/{ps}/{mi}/intrinsic_split_decomp.npz",
        donuts = "output/{ps}/donuts.parquet",
        visits = "output/{ps}/visits.parquet",
        config = "mi_config.yaml",
        script = "code/run_make_intrinsic_sidecar.py",
        lib    = "code/intrinsic_split.py",
    output: "output/{ps}/{mi}/zk_intrinsic.parquet"
    resources: mem_mb=8000
    log: "logs/{ps}.{mi}.intrinsic_sidecar.log"
    shell:
        "python code/run_make_intrinsic_sidecar.py --param-set {wildcards.ps} "
        "--mi-name {wildcards.mi} > {log} 2>&1"

# ---- refit the Double Zernikes using the measured intrinsic ----
rule refit_mi:
    input:
        donuts  = "output/{ps}/donuts.parquet",
        visits  = "output/{ps}/visits.parquet",
        sidecar = "output/{ps}/{mi}/zk_intrinsic.parquet",
        script  = "code/run_dz_fit.py",
        lib     = "code/dz_fitting.py",
    output: "output/{ps}/{mi}/fits.parquet"
    params: coord = lambda w: coord(w.ps)
    resources: mem_mb=4000
    log: "logs/{ps}.{mi}.refit_mi.log"
    shell:
        "python code/run_dz_fit.py {input.donuts} --coord-sys {params.coord} "
        "--visits {input.visits} --intrinsic-sidecar {input.sidecar} "
        "--output {output} > {log} 2>&1"

# ---- averaged-DOF LUT (n_dof/n_keep settable; collapses elev+rotator) ----
rule build_lut:
    input:
        fits     = "output/{ps}/fits.parquet",
        visits   = "output/{ps}/visits.parquet",
        config   = "mi_config.yaml",           # SVD params, filters, n_dof/n_keep
        analysis = "analysis_config.yaml",      # lut knobs (reduce, alt window, ...)
        script   = "code/run_build_lut.py",
        lib      = "code/ofc_svd.py",
    output:
        lut    = "output/{ps}/{mi}/lut/lut.parquet",
        lut_dz = "output/{ps}/{mi}/lut/lut_dz.parquet",
        plots  = "output/{ps}/{mi}/lut/lut.pdf",
    resources: mem_mb=4000
    log: "logs/{ps}.{mi}.build_lut.log"
    shell:
        "python code/run_build_lut.py --param-set {wildcards.ps} "
        "--mi-name {wildcards.mi} > {log} 2>&1"
