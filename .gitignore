# ===== Jupyter =====
.ipynb_checkpoints/

# ===== Python =====
__pycache__/
*.pyc
*.pyo
*.egg-info/
*.egg
dist/
build/
.eggs/
*.so

# ===== Virtual environments =====
.venv/
venv/
env/

# ===== Output directories (large/ephemeral outputs) =====
# Keep .gitkeep files but ignore everything else in output/
*/output/*
!*/output/.gitkeep
# Archived output snapshots (e.g. aos/output-backup/) — never track these.
*-backup/

# ===== Log directories (per-run logs are ephemeral) =====
*/logs/*
!*/logs/.gitkeep

# ===== Large data files =====
*.fits
*.fits.gz
*.fits.fz
*.fz
*.parquet
*.hdf5
*.h5
*.pkl
*.pickle

# Exception: versioned AOS calibration products are small and tracked on purpose
# (see aos/calibration/README.md). Negation must come after the *.parquet rule.
!aos/calibration/**/*.parquet

# ===== OS clutter =====
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# ===== Editor/IDE =====
.vscode/
.idea/
*.swp
*.swo
*~

# ===== Misc =====
.env
*.log

# Session handoff snapshots (local-only, not auto-updated)
aos/AOS_SESSION_HANDOFF.md
aos/SESSION_HANDOFF.md
