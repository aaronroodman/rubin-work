# ===== Output directories (large/ephemeral outputs) =====
# Keep .gitkeep files but ignore everything else in output/
*/output/*
!*/output/.gitkeep
!blocks/output/*.txt
!blocks/output/*.csv
!blocks/output/*.csv.gz
# Keep aos pipeline log files (small, useful for tracking runs across machines)
!aos/output/log/
!aos/output/log/*.log

