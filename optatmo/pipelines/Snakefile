# ----------------------------------------------------------------------
# optatmo Optics+Atmosphere PSF-moment fit pipeline (Snakemake).
#
# Chain, per in-focus visit (seq):
#
#   export_miw ─┐
#   extract_psf ┼─> fit ─> plots
#   extract_cwfs┘                (corner comparison uses cwfs + official MIW)
#
# export_miw runs once (dumps the official ip_isr intrinsicZernikes calib to
# parquet); extract_psf / extract_cwfs run per visit (Butler, parallelisable);
# fit and plots run per seq.
#
# Run from the optatmo/ ROOT (so data/, config.yaml, ../aos/ resolve):
#
#   cd rubin-work/optatmo
#   source /sdf/group/rubin/sw/tag/w_2026_27/loadLSST.bash && setup lsst_distrib
#   snakemake -s pipelines/Snakefile -n            # dry-run: show the plan
#   snakemake -s pipelines/Snakefile -j4           # build (4 parallel)
#   snakemake -s pipelines/Snakefile --dag | dot -Tpng > pipelines/dag.png
#
# Everything (Butler, ip_isr, obs_lsst, jax) is in the lsst_distrib weekly — no
# AOS env needed.  Config: pipelines/config.yaml.
# ----------------------------------------------------------------------
import os

# one thread per job; parallelism comes from `snakemake -j`
for _v in ('OMP_NUM_THREADS', 'OPENBLAS_NUM_THREADS', 'MKL_NUM_THREADS',
           'NUMEXPR_NUM_THREADS'):
    os.environ[_v] = '1'

configfile: "pipelines/config.yaml"

DAY   = int(config["day"])
SEQS  = [int(s) for s in config["seqs"]]
SVD   = config["svd_npz"]
REG   = config["reg"]
CODE  = "code"


def visit(seq):
    return int(f"{DAY}{seq:05d}")


VISITS = [visit(s) for s in SEQS]

wildcard_constraints:
    seq   = r"\d+",
    visit = r"\d+",

PLOTS = ["fwhm", "ellip", "coma", "trefoil", "corners"]


rule all:
    input:
        "output/miw_z4_ocs_ccs.png",
        "output/miw_ocs_z5_z11.png",
        expand("output/dm_{p}_{seq}.png", p=PLOTS, seq=SEQS)


# ---- validation plots of the official MIW maps ----
rule plot_miw:
    output:
        "output/miw_z4_ocs_ccs.png",
        "output/miw_ocs_z5_z11.png",
    input:
        ocs    = "data/intrinsic_official_ocs.parquet",
        ccs    = "data/intrinsic_official_ccs.parquet",
        script = f"{CODE}/plot_miw_maps.py",
    log: "pipelines/logs/plot_miw.log"
    shell:
        "python {input.script} --ocs {input.ocs} --ccs {input.ccs} "
        "--out-dir output &> {log}"


# ---- official MIW calibration (once) -> OCS + per-detector CCS + names ----
rule export_miw:
    output:
        ocs   = "data/intrinsic_official_ocs.parquet",
        ccs   = "data/intrinsic_official_ccs.parquet",
        names = "data/detector_names.parquet",
    input:
        script = f"{CODE}/export_official_miw.py",
    params:
        coll = config["miw_collection"], filt = config["filter"],
        repo = config["repo"],
    log: "pipelines/logs/export_miw.log"
    shell:
        "python {input.script} --out-dir data --collection {params.coll} "
        "--filter {params.filt} --repo {params.repo} &> {log}"


# ---- per-visit PSF-star moment extraction (Butler) ----
rule extract_psf:
    output:
        "data/psfmoments_{visit}.parquet",
    input:
        script = f"{CODE}/extract_psf_moments.py",
        hsm    = f"{CODE}/moments_hsm.py",
    params:
        coll = config["psf_collection"], repo = config["repo"],
        mpc = config["max_per_ccd"], snr = config["snr_min"],
    log: "pipelines/logs/extract_psf.{visit}.log"
    shell:
        "python {input.script} --visits {wildcards.visit} "
        "--collection {params.coll} --repo {params.repo} --out-dir data "
        "--max-per-ccd {params.mpc} --snr-min {params.snr} &> {log}"


# ---- per-visit corner-WFS aggregate Zernikes (Butler) ----
rule extract_cwfs:
    output:
        "data/cwfs_{visit}.parquet",
    input:
        script = f"{CODE}/extract_cwfs.py",
    params:
        coll = config["cwfs_collection"], repo = config["repo"],
    log: "pipelines/logs/extract_cwfs.{visit}.log"
    shell:
        "python {input.script} --visits {wildcards.visit} "
        "--collection '{params.coll}' --repo {params.repo} --out-dir data &> {log}"


# ---- per-seq v-mode fit ----
rule fit:
    output:
        "data/vmodefit_{seq}.npz",
    input:
        psf   = lambda w: f"data/psfmoments_{visit(int(w.seq))}.parquet",
        ocs   = "data/intrinsic_official_ocs.parquet",
        ccs   = "data/intrinsic_official_ccs.parquet",
        svd   = SVD,
        script = f"{CODE}/run_vmode_fit.py",
        deps  = [f"{CODE}/{m}.py" for m in
                 ("miw", "data_fit", "vmode_fit", "model", "fit", "config",
                  "frames", "jax_optatmo", "jax_hsm")],
    log: "pipelines/logs/fit.{seq}.log"
    shell:
        "python {input.script} 1 {input.svd} reg={REG} "
        "seqs={wildcards.seq} day={DAY} &> {log}"


# ---- per-seq data-vs-model + corner comparison plots ----
rule plots:
    output:
        expand("output/dm_{p}_{{seq}}.png", p=PLOTS),
    input:
        fit   = "data/vmodefit_{seq}.npz",
        cwfs  = lambda w: f"data/cwfs_{visit(int(w.seq))}.parquet",
        psf   = lambda w: f"data/psfmoments_{visit(int(w.seq))}.parquet",
        ocs   = "data/intrinsic_official_ocs.parquet",
        ccs   = "data/intrinsic_official_ccs.parquet",
        names = "data/detector_names.parquet",
        svd   = SVD,
        script = f"{CODE}/plot_data_model.py",
        deps  = [f"{CODE}/{m}.py" for m in ("miw", "data_fit", "vmode_fit",
                                            "model", "fit", "config", "frames")],
    log: "pipelines/logs/plots.{seq}.log"
    shell:
        "python {input.script} {input.svd} seqs={wildcards.seq} day={DAY} &> {log}"
